{
    "name": "kahani-backend",
    "version": "1.0.0",
    "description": "Backend for the Kahani project",
    "main": "dist/index.js",
    "scripts": {
      "build": "tsc",
      "start": "node dist/index.js",
      "dev": "nodemon",
      "test": "jest",
      "lint": "eslint . --ext .ts",
      "prettier": "prettier . --write"
    },
    "author": "Siddharth Thakur",
    "license": "MIT",
    "dependencies": {
      "body-parser": "^1.19.0",
      "cors": "^2.8.5",
      "express": "^4.17.1",
      "pg": "^8.7.1",
      "sequelize": "^6.6.5",
      "sequelize-typescript": "^2.1.0"
    },
    "devDependencies": {
      "@types/body-parser": "^1.19.0",
      "@types/cors": "^2.8.12",
      "@types/express": "^4.17.13",
      "@types/jest": "^27.0.2",
      "@types/node": "^16.9.0",
      "@typescript-eslint/eslint-plugin": "^4.29.3",
      "@typescript-eslint/parser": "^4.29.3",
      "eslint": "^7.32.0",
      "jest": "^27.2.3",
      "nodemon": "^2.0.12",
      "prettier": "^2.3.2",
      "ts-jest": "^27.0.5",
      "ts-node": "^10.2.1",
      "typescript": "^4.4.2"
    },
    "jest": {
      "preset": "ts-jest"
    },
    "eslintConfig": {
      "extends": [
        "eslint:recommended",
        "plugin:@typescript-eslint/recommended"
      ],
      "parser": "@typescript-eslint/parser",
      "plugins": [
        "@typescript-eslint"
      ],
      "rules": {
        "semi": ["error", "always"],
        "quotes": ["error", "single"],
        "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
        "comma-dangle": ["error", "always-multiline"],
        "space-before-function-paren": ["error", "never"]
      }
    }
  }
  